# BRC Tools Environment Variables
# Copy to .env and fill in your actual values

# Required for uploads to BasinWX (32-char hex)
DATA_UPLOAD_API_KEY=your_32char_hex_key_here

# Required for Synoptic obs downloads (SynopticPy >=2024.0.0)
# Also configurable via ~/.config/SynopticPy/config.toml
SYNOPTIC_TOKEN=your_synoptic_token_here

# Optional: aviation module
FLIGHTAWARE_API_KEY=your_flightaware_api_key_here

# Optional: NWP cache and lock directories
# BRC_TOOLS_HERBIE_CACHE=~/data/herbie_cache
# BRC_TOOLS_LOCK_DIR=/tmp

# Optional: parallel download threads
# MODEL_DOWNLOAD_THREADS=4
